db#db_pb_ui_test(name="ui_tests" scope="ui_elements")
    d(name="button_test" type="panel" interactive="true" event="button_test"
        triggerstate="[~ui_tests_states]"
        x=50 y=50 rx=0 ry=10 w=35 h=8 scale=1
        color="0x0" colorb="0xffffff" glow="1" opacity="1" corner="0.3")
    d(name="button_test_icon" type="sprite" sprite="check"
        pivot="button_test"
        z=1 rx=-10 anchorx=1 anchory=0.5
        size="4" opacity="1" colorb="0xffffff" glow="1")
    d(name="button_test_label" type="text" font="afont"
        z=1 pivot="button_test"
        text="test_ok" fontsize="4" color="0xffffff" colorb="0xffffff" glow="1" opacity="1"
        anchorx=0.5 anchory=0.5)

db#db_pb_ui_dev_elements(name="ui_dev_elements" scope="ui_elements")
    //- 2026-06-14, Composer: debug square panel top-left check label [uidv1]
    d(name="debug_button" type="panel" interactive="true" event="debug_button"
        x=0 y=100 rx=4 ry=-4 w=6 h=6 scale=1
        color="0x0" colorb="0xffffff" glow="1" opacity="1" corner="0.3")
    d(name="debug_button_icon_cross" type="sprite" sprite="cross"
        pivot="debug_button"
        z=1 anchorx=0.5 anchory=0.5
        size="4" opacity="1" colorb="0xffffff" glow="1")
    d(name="debug_button_icon_check" inherits="debug_button_icon_cross"
        sprite="check" opacity="0")
    d(name="debug_button_label" type="text" font="afont"
        pivot="debug_button"
        z=1 rx=4 text="debug" fontsize="4"
        color="0xffffff" colorb="0xffffff" glow="1" opacity="1"
        anchorx=0 anchory=0.5)

db#db_pb_ui_loading_elements(name="ui_loading_elements" scope="ui_elements")
    d(name="loading_bg" type="panel"
        z=1 x=50 y=50
        w=80 h=80 scale=1
        color="0x0" colorb="0xffffff" glow="4" opacity=0.5 corner=0.1)
    d(name="loading_text" type="text" font="afont"
        z=2 x=50 y=50
        text="loading" fontsize="22" color="0xffffff" colorb="0xffffff" glow="1" opacity="1"
        anchorx=0.5 anchory=0.5)

db#db_pb_ui_loading(name="ui_loading" scope="ui_states")
    d(name="loading_elements" element="[loading_bg,loading_text]")

db#db_pb_ui_dev(name="ui_dev" scope="ui_states")
    //- 2026-06-14, Composer: hide elements until active state refs them [uivis1]
    d(name="dev_elements" element="[debug_button, debug_button_icon_cross, debug_button_icon_check, debug_button_label]")

db#db_pb_ui_tests_vis(name="ui_tests_vis" scope="ui_states")
    d(name="tests_elements" element="[button_test, button_test_icon, button_test_label]")

db#db_pb_ui_debug_enabled(name="ui_debug_enabled" scope="ui_states")
    //- 2026-06-14, Composer: rename ui_dev_states to ui_debug_enabled [stgs2]
    //- 2026-06-14, Composer: hide elements until active state refs them [uivis1]
    d(name="debug_button_icon_cross" opacity="0")
    d(name="debug_button_icon_check" opacity="1")

db#db_pb_ui_tests_states(name="ui_tests_states" scope="ui_states")
    d(name="button_test_state_default" element="button_test"
        ry=-10)
