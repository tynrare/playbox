   d(name="coin_a"                source="props" object="coin_a" material="coin_a")
   //- 2026-06-26, Composer: coin_b model inherits coin_a object coin_b [mdcnb1]
   d(name="coin_b"                inherits="coin_a" object="coin_b")
   //- 2026-06-26, Composer: coin_c model inherits coin_a object coin_c [mdcnc1]
   d(name="coin_c"                inherits="coin_a" object="coin_c")
   //- 2026-06-26, Composer: dice_a model inherits coin_a object dice_a [mddca1]
   d(name="dice_a"                inherits="coin_a" object="dice_a")
   //- 2026-06-27, Composer: weight_a model inherits coin_a object weight_a [mdwta1]
   d(name="weight_a"              inherits="coin_a" object="weight_a")
   //- 2026-06-27, Composer: arcader_a RigidModel parts wildcard [mdarc1]
   //- 2026-06-28, Composer: arcader_a parts exclude welded button [mdarc2]
   d(name="arcader_a"              source="props" object="arcader_a"
      parts="[arcader_a, arcader_a_revolver_0]")
   //- 2026-06-28, Composer: arcader_a_button single mesh model [mdarcb1]
   d(name="arcader_a_button"        source="props" object="arcader_a_button")

