db#db_pb_materials(name="materials")
   d(name="material_proto" id="0")
   d(name="scenematerial" type="standard" color="0xffffff" glow="0" opacity="1")
   d(name="coin_a" type="phong" shininess="10" emissive="0xffffff" glow="1")

//- 2026-06-18, Composer: collapse models_instanced into models [mdcol1]
db#db_pb_models(name="models")
